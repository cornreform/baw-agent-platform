#!/usr/bin/env -S uv run python
"""
BAW Agent Platform — CLI Entry Point
Linux + macOS compatible

Usage:
  baw <prompt>                    Run agent with a prompt
  baw --help                      Show this help
  baw --version                   Show version
  baw --version                   Show version

Subcommands:
  baw --remember <text>           Store a memory entry
  baw --search <query>            Search stored memories
  baw --status                    Show BAW status (model, memory, tools)
  baw --dream                     Run weekly self-curation (silent unless changes)
  baw --search-provider list      List available web search providers
  baw --search-provider guide <name>  Show setup guide for a provider
  baw --search-provider api <name>    Show API reference for a provider
  baw --search-provider test <name> <query>  Test a search provider

Options:
  --model, -m  <id>               Override model (e.g. MiniMax-M3, deepseek-v4-flash)
  --tone, -t   <profile>          Override tone (casual / business / teaching / client-doc / ot-rt / stepwise)
  --verbose, -v                   Verbose output with LLM call info
  --dry-run, -n                   Dry run — no file changes
  --config     <path>             Path to custom config.yaml

Available tools:
  bash        Execute shell commands
  read_file   Read file contents
  write_file  Write content to a file
  web_search  Search the web (DuckDuckGo, no API key required)

Architecture:
  BAW runs a self-improving agent loop with Angel/Devil adversarial court,
  auto-fallback between models, auto-save to git, file history tracking,
  and web search for fact checking. See SOUL.md for behaviour rules.

Default model: Kimi K2.6 (fallback: DeepSeek V4 Flash)
"""

import sys
import os
import json
import argparse
from pathlib import Path

# Add BAW paths
BAW_ROOT = Path(__file__).parent.resolve()
sys.path.insert(0, str(BAW_ROOT))
sys.path.insert(0, str(BAW_ROOT.parent.resolve()))

BAW_VERSION = "1.0.0"


def main():
    parser = argparse.ArgumentParser(
        description="BAW (Black And White) — Agent Platform",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""Available tools:
  bash        Execute shell commands
  read_file   Read file contents
  write_file  Write content to a file
  web_search  Search the web (DuckDuckGo, no API key)

Slash commands (interactive mode):
  /help       Show available commands
  /status     Show BAW status
  /version    Show version + git log
  /remember   Store a memory entry
  /search     Search memories
  /model      Switch model
  /tone       Switch tone profile
  /dream      Run self-curation
  /tools      List registered tools
  /provider   Search provider ops
  /rethink    Rerun last prompt with alternative analysis
  /court      Show last Angel/Devil verdict
  /fresh      Raw model — no soul, no memories

Examples:
  baw "list files in current directory"
  baw --model MiniMax-M3 "describe this image"
  baw --tone business "write a proposal"
  baw --verbose "debug the server"
  baw --remember "always use Traditional Chinese"
  baw --search "memory keyword"
  baw --status
  baw --search-provider list
  baw --search-provider test duckduckgo "latest Linux kernel version"
        """,
    )
    parser.add_argument("prompt", nargs="*", help="Prompt for the agent")
    parser.add_argument("--model", "-m", help="Override model (e.g. MiniMax-M3)")
    parser.add_argument("--mode", choices=["quick", "hybrid", "tight"], default=None,
                        help="Execution mode: quick (no court/plan), hybrid (plan only), tight (full court+plan)")
    parser.add_argument("--tone", "-t", help="Override tone (casual / business / teaching / client-doc / ot-rt / stepwise)")
    parser.add_argument("--verbose", "-v", action="store_true", help="Verbose output")
    parser.add_argument("--dry-run", "-n", action="store_true", help="Dry run (no changes)")
    parser.add_argument("--btw", action="store_true",
                        help="BTW mode: quick question, no court/plan/tools")
    parser.add_argument("--delegate", nargs="?", const=True, default=None,
                        help="Delegate a task to background executor (optionally specify prompt)")
    parser.add_argument("--task-id", help="Check background task status (without prompt) or run as executor (with prompt)")
    parser.add_argument("--config", help="Path to config.yaml")
    parser.add_argument("--version", action="store_true", help="Show BAW version and exit")

    # Subcommands
    subcommands = parser.add_argument_group("subcommands")
    subcommands.add_argument("--remember", help="Store a memory entry")
    subcommands.add_argument("--search", help="Search memory")
    subcommands.add_argument("--status", action="store_true", help="Show BAW status")
    subcommands.add_argument("--dream", action="store_true", help="Run weekly self-curation (silent)")
    subcommands.add_argument("--search-provider", nargs="+",
                             help="Commands: list | guide <name> | api <name> | test <name> <query>")
    subcommands.add_argument("--tasks", action="store_true", help="List all background tasks with status")
    subcommands.add_argument("--task-cancel", metavar="TASK_ID", help="Cancel a running/queued task")
    subcommands.add_argument("--gh", nargs="+",
                             help="GitHub commands: issues <repo> | prs <repo> | create-issue <repo> <title> <body> | ci <repo> | repos <owner> | setup | status")
    subcommands.add_argument("--schedule-list", action="store_true", help="List all scheduled tasks")
    subcommands.add_argument("--schedule-add", nargs=3, metavar=("NAME", "CRON", "COMMAND"),
                             help="Add a scheduled task: --schedule-add mytask '0 9 * * *' 'do something'")
    subcommands.add_argument("--schedule-rm", metavar="NAME", help="Remove a scheduled task")
    subcommands.add_argument("--skill-list", action="store_true", help="List all available skills")
    subcommands.add_argument("--skill-run", metavar="NAME", help="Run a skill by name")
    subcommands.add_argument("--skill-args", default="",
                             help="Arguments to pass to the skill (use with --skill-run)")
    subcommands.add_argument("--learn-skill", metavar="DESCRIPTION",
                             help="Autonomously learn and create a skill from a description")
    subcommands.add_argument("--learn-url", metavar="URL",
                             help="Fetch a URL and learn a skill from its content")
    subcommands.add_argument("--board", action="store_true", help="Generate HTML dashboard")

    args = parser.parse_args()

    # --version
    if args.version:
        try:
            log = os.popen("cd " + str(BAW_ROOT) + " && git log --oneline -1 2>/dev/null").read().strip()
        except Exception:
            log = "unknown"
        print(f"BAW (Black And White) Agent Platform v{BAW_VERSION}")
        print(f"Commit: {log}")
        print(f"Home: {BAW_ROOT}")
        print("Architecture: self-improving loop with Angel/Devil adversarial court")
        return

    # Load config
    from baw.core.llm import load_config
    config_path = Path(args.config) if args.config else None
    try:
        config = load_config(config_path)
    except FileNotFoundError:
        default_cfg = BAW_ROOT / "config.yaml"
        if default_cfg.exists():
            config = load_config(default_cfg)
        else:
            print("Error: config.yaml not found. Create ~/.baw/config.yaml or run from BAW directory.")
            sys.exit(1)

    # Override tone if specified
    if args.tone:
        config.setdefault("tone", {})["default"] = args.tone

    # Initialize data directory
    data_dir = Path.home() / ".baw"
    data_dir.mkdir(parents=True, exist_ok=True)

    # ── BTW: quick question, no overhead ──
    if args.btw:
        prompt = " ".join(args.prompt) if args.prompt else ""
        if not prompt:
            print("Error: --btw requires a prompt (e.g. baw --btw \"what time is it\")")
            sys.exit(1)
        from baw.core.llm import call_llm_with_fallback, calculate_cost, get_model
        from baw.core.loop import build_system_prompt
        from baw.core.display import btw_header

        model = get_model(config)
        sys_prompt = build_system_prompt(config, data_dir)
        msgs = [{"role": "system", "content": sys_prompt}, {"role": "user", "content": prompt}]
        fb = call_llm_with_fallback(config, msgs, temperature=0.7)
        cost = calculate_cost(model, fb.response.input_tokens, fb.response.output_tokens)
        print(f"{btw_header()}{fb.response.content}\n")
        print(f"  ⚡ {cost:.4f} | {fb.response.input_tokens}↑{fb.response.output_tokens}↓")
        return

    # ── Background delegation (using TaskManager) ──
    if args.delegate:
        prompt = " ".join(args.prompt) if args.prompt else args.delegate
        if not prompt:
            print("Error: --delegate requires a prompt or plan")
            sys.exit(1)
        from baw.core.task_manager import TaskManager
        tm = TaskManager(data_dir)
        task = tm.submit(prompt, mode=args.mode or "hybrid")
        from baw.core.display import front_desk_task_id
        print(front_desk_task_id(task.id))
        return

    # ── Check background task status (without prompt) ──
    if args.task_id and not args.prompt:
        task_dir = data_dir / "tasks" / args.task_id
        if not task_dir.exists():
            print(f"❌ Task {args.task_id} not found")
            sys.exit(1)
        status = (task_dir / "status.txt").read_text(encoding="utf-8").strip() if (task_dir / "status.txt").exists() else "unknown"
        prompt_text = (task_dir / "prompt.txt").read_text(encoding="utf-8") if (task_dir / "prompt.txt").exists() else ""
        stdout_text = (task_dir / "stdout.txt").read_text(encoding="utf-8") if (task_dir / "stdout.txt").exists() else ""
        print(f"📋 Task: {args.task_id}")
        print(f"   Status: {status}")
        if prompt_text:
            print(f"   Goal: {prompt_text[:100]}")
        if stdout_text:
            print(f"\n{stdout_text[:1000]}")
        return

    # ── Background executor mode: run and save to task dir ──
    if args.task_id and args.prompt:
        prompt = " ".join(args.prompt)
        task_dir = data_dir / "tasks" / args.task_id
        task_dir.mkdir(parents=True, exist_ok=True)
        (task_dir / "status.txt").write_text("running", encoding="utf-8")
        # Run the agent
        from baw.tools import register_all as reg_tools
        from baw.core.loop import run_agent
        reg_tools()
        response, info = run_agent(
            prompt=prompt,
            config=config,
            model_id=args.model,
            data_dir=data_dir,
            verbose=False,
            interactive=False,
            mode=args.mode or "tight",
        )
        # Save output
        (task_dir / "stdout.txt").write_text(response, encoding="utf-8")
        (task_dir / "status.txt").write_text("done", encoding="utf-8")
        (task_dir / "info.json").write_text(__import__("json").dumps(info), encoding="utf-8")
        return

    # Subcommands
    if args.remember:
        from baw.core.memory import MemoryStore
        mem = MemoryStore(data_dir)
        result = mem.remember(args.remember)
        print(f"Remembered (score: {result['score']:.2f})")
        return

    if args.search:
        from baw.core.memory import MemoryStore
        mem = MemoryStore(data_dir)
        results = mem.search(args.search)
        if not results:
            print("No results found.")
            return
        for r in results:
            print(f"[{r['score']:.2f}] {r['content'][:100]}")
        return

    # Search provider subcommands
    if args.search_provider:
        _handle_search_provider(args.search_provider)
        return

    # ── Task management ──
    if args.tasks:
        from baw.core.task_manager import TaskManager
        tm = TaskManager(data_dir)
        print(tm.summary())
        return

    if args.task_cancel:
        from baw.core.task_manager import TaskManager
        tm = TaskManager(data_dir)
        if tm.cancel(args.task_cancel):
            print(f"✅ Cancelled task {args.task_cancel}")
        else:
            print(f"❌ Task {args.task_cancel} not found")
        return

    # ── GitHub ──
    if args.gh:
        from baw.core.github import (
            list_issues, create_issue, close_issue,
            list_prs, pr_status,
            list_workflows, list_runs,
            list_repos, baw_status, setup_guide,
        )
        cmd = args.gh[0]
        rest = args.gh[1:]

        if cmd == "setup":
            print(setup_guide())
        elif cmd == "status":
            print(baw_status())
        elif cmd == "issues" and rest:
            state = "open"
            repo = rest[0]
            if len(rest) > 1 and rest[1] in ("open", "closed", "all"):
                state = rest[1]
            issues = list_issues(repo, state)
            if issues and issues[0].get("error"):
                print(f"❌ {issues[0]['error']}")
            else:
                print(f"📋 {repo} issues ({state}):")
                for i in issues[:15]:
                    print(f"  #{i.get('number', '?')} {i.get('title', '?')[:70]}")
        elif cmd == "create-issue" and len(rest) >= 2:
            repo = rest[0]
            title = rest[1]
            body = " ".join(rest[2:]) if len(rest) > 2 else "Created by BAW"
            result = create_issue(repo, title, body)
            if result.get("error"):
                print(f"❌ {result['error']}")
            else:
                print(f"✅ Created: {result['url']}")
        elif cmd == "close-issue" and len(rest) >= 2:
            repo = rest[0]
            try:
                num = int(rest[1])
                result = close_issue(repo, num)
                if result.get("error"):
                    print(f"❌ {result['error']}")
                else:
                    print(f"✅ Closed #{num}")
            except ValueError:
                print("❌ Issue number must be an integer")
        elif cmd == "prs" and rest:
            state = "open"
            repo = rest[0]
            if len(rest) > 1 and rest[1] in ("open", "closed", "merged", "all"):
                state = rest[1]
            prs = list_prs(repo, state)
            if prs and prs[0].get("error"):
                print(f"❌ {prs[0]['error']}")
            else:
                print(f"🔀 {repo} PRs ({state}):")
                for p in prs[:10]:
                    print(f"  #{p.get('number', '?')} {p.get('title', '?')[:70]}")
        elif cmd == "ci" and rest:
            repo = rest[0]
            branch = rest[1] if len(rest) > 1 else ""
            runs = list_runs(repo, branch)
            if runs and runs[0].get("error"):
                print(f"❌ {runs[0]['error']}")
            else:
                print(f"🔄 {repo} CI runs:")
                for r in runs[:10]:
                    status = r.get("conclusion", r.get("status", "?"))
                    print(f"  {r.get('displayTitle', '?')[:50]} — {status}")
        elif cmd == "repos":
            owner = rest[0] if rest else ""
            repos = list_repos(owner)
            if repos and repos[0].get("error"):
                print(f"❌ {repos[0]['error']}")
            else:
                print(f"📦 Repos:")
                for r in repos[:20]:
                    name = r.get("name", "?")
                    desc = (r.get("description", "") or "")[:50]
                    print(f"  {name}  — {desc}")
        else:
            print("Usage: --gh {setup|status|issues <repo> [state]|create-issue <repo> <title> [body]|close-issue <repo> <num>|prs <repo> [state]|ci <repo> [branch]|repos [owner]}")
        return

    if args.status:
        from baw.core.memory import MemoryStore
        mem = MemoryStore(data_dir)
        stats = mem.stats()
        print("BAW Status")
        print(f"  Memory: {stats['total']} entries")
        if stats['total'] > 0:
            print(f"  Avg score: {stats['avg_score']:.2f}")
            print(f"  High score: {stats['high_score']:.2f}")
            print(f"  Low score: {stats['low_score']:.2f}")
        print(f"  Config: {config_path or 'built-in'}")
        return

    if args.dream:
        from baw.core.dream import dream
        report = dream(data_dir, dry_run=args.dry_run)
        if report["changes"]:
            print(json.dumps(report, ensure_ascii=False, indent=2))
        return

    # ── Schedule commands ──
    if args.schedule_list:
        from baw.core.scheduler import Scheduler
        sched = Scheduler(data_dir)
        print(sched.status_report())
        return

    if args.schedule_add:
        name, cron_expr, command = args.schedule_add
        from baw.core.scheduler import Scheduler, ScheduledTask
        sched = Scheduler(data_dir)
        sched.add_task(ScheduledTask(name=name, cron=cron_expr, command=command))
        print(f"✅ Scheduled '{name}' — `{cron_expr}` → `{command[:60]}`")
        return

    if args.schedule_rm:
        from baw.core.scheduler import Scheduler
        sched = Scheduler(data_dir)
        if sched.remove_task(args.schedule_rm):
            print(f"✅ Removed '{args.schedule_rm}'")
        else:
            print(f"❌ Task '{args.schedule_rm}' not found")
        return

    # ── Skill commands ──
    if args.skill_list:
        from baw.core.skills import SkillRegistry
        reg = SkillRegistry(data_dir)
        print(reg.status_report())
        return

    if args.skill_run:
        from baw.core.skills import SkillRegistry
        from baw.tools import register_all as reg_tools
        from baw.core.loop import run_agent
        reg_tools()
        reg = SkillRegistry(data_dir)
        skill = reg.get_skill(args.skill_run)
        if not skill:
            print(f"❌ Skill '{args.skill_run}' not found")
            sys.exit(1)
        # Run each step sequentially
        for i, step in enumerate(skill.steps):
            prompt = skill.build_prompt(i, args.skill_args)
            print(f"🧠 Skill step {i+1}/{len(skill.steps)}: {step.get('name', '?')}")
            resp, info = run_agent(
                prompt=prompt,
                config=config,
                data_dir=data_dir,
                mode=skill.get_mode(),
                verbose=args.verbose,
                interactive=False,
            )
            print(resp)
            if info.get("adversarial") == "flagged":
                print(f"⛔ Blocked at step {i+1}")
                break
        return

    # ── Board / Dashboard ──
    if args.board:
        from baw.core.board import generate as gen_board
        path = gen_board(data_dir)
        print(f"📊 Dashboard: {path}")
        return

    # ── Learn skill ──
    if args.learn_skill:
        from baw.core.learn import learn_from_description
        if not args.learn_skill.strip():
            print("❌ Please provide a skill description")
            sys.exit(1)
        print(f"🧠 Learning skill from description...")
        result = learn_from_description(args.learn_skill, data_dir, config,
                                         verbose=args.verbose, dry_run=args.dry_run)
        if result["error"]:
            print(f"❌ {result['error']}")
        else:
            print(f"✅ Created skill '{result['name']}' — {result['steps']} steps")
            if result["file"]:
                print(f"   Saved: {result['file']}")
            if args.verbose:
                print(f"\n─── Analysis ───\n{result['analysis'][:500]}")
        return

    if args.learn_url:
        from baw.core.learn import learn_from_url
        if not args.learn_url.strip():
            print("❌ Please provide a URL")
            sys.exit(1)
        print(f"🌐 Fetching {args.learn_url}...")
        result = learn_from_url(args.learn_url, data_dir, config,
                                 verbose=args.verbose, dry_run=args.dry_run)
        if result["error"]:
            print(f"❌ {result['error']}")
        else:
            print(f"✅ Created skill '{result['name']}' — {result['steps']} steps")
            if result["file"]:
                print(f"   Saved: {result['file']}")
            if args.verbose:
                print(f"\n─── Analysis ───\n{result['analysis'][:500]}")
        return

    # Agent mode
    prompt = " ".join(args.prompt) if args.prompt else None
    if not prompt:
        print("BAW Interactive Mode (Ctrl+D to exit)")
        from baw.core.commands import handle_slash
        while True:
            try:
                user_input = input("\n>> ")
                if not user_input.strip():
                    continue
                # Check for slash command
                if user_input.startswith("/"):
                    parts = user_input[1:].strip().split(None, 1)
                    cmd = parts[0] if parts else ""
                    cmd_args = parts[1].split() if len(parts) > 1 else []
                    result = handle_slash(cmd, cmd_args, config, data_dir, args.verbose)
                    if result is not None:
                        print(result)
                        continue
                _run_single(user_input, config, args, data_dir)
            except (EOFError, KeyboardInterrupt):
                print()
                break
    else:
        # Check for slash command in single-shot mode
        if prompt.startswith("/"):
            parts = prompt[1:].strip().split(None, 1)
            cmd = parts[0] if parts else ""
            cmd_args = parts[1].split() if len(parts) > 1 else []
            from baw.core.commands import handle_slash
            result = handle_slash(cmd, cmd_args, config, data_dir, args.verbose)
            if result is not None:
                print(result)
                return
        _run_single(prompt, config, args, data_dir)


def _run_single(prompt: str, config: dict, args, data_dir: Path):
    """Run a single prompt and print result."""
    from baw.tools import register_all
    from baw.core.loop import run_agent
    register_all()

    try:
        response, info = run_agent(
            prompt=prompt,
            config=config,
            model_id=args.model,
            data_dir=data_dir,
            verbose=args.verbose,
            interactive=True,
            mode=args.mode,
        )
        print(f"\n{response}")
        if args.verbose:
            cost_line = f"[{info['model']}] iterations: {info.get('iterations', '?')} ${info['cost']:.6f}"
            print(f"\n{cost_line}")

        # Save state for /rethink and /court
        from baw.core.commands import set_last_run
        set_last_run(prompt, info)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        if args.verbose:
            import traceback
            traceback.print_exc()


def _handle_search_provider(args: list[str]):
    """Handle --search-provider subcommand."""
    if not args:
        print("Usage: baw --search-provider list|guide <name>|api <name>|test <name> <query>")
        return

    action = args[0]
    BAW_ROOT = Path(__file__).parent.resolve()

    sys.path.insert(0, str(BAW_ROOT))
    from baw.core.search import (
        list_providers, get_setup_guide, get_api_reference, search,
    )
    from baw.core.search import _auto_discover as _init_search
    _init_search()

    if action == "list":
        providers = list_providers()
        if not providers:
            print("No search providers registered.")
            return
        print("Available Search Providers:")
        print()
        for p in providers:
            key_status = "API key required" if p["requires_api_key"] else "No API key needed"
            print(f"  {p['name']}")
            print(f"    {p['description']}")
            print(f"    {key_status}")
            if p["env_var"]:
                print(f"    Env var: {p['env_var']}")
            print()

    elif action == "guide" and len(args) >= 2:
        try:
            guide = get_setup_guide(args[1])
            print(guide)
        except ValueError as e:
            print(f"Error: {e}")
            print(f"Available: {[p['name'] for p in list_providers()]}")

    elif action == "api" and len(args) >= 2:
        try:
            ref = get_api_reference(args[1])
            print(ref)
        except ValueError as e:
            print(f"Error: {e}")

    elif action == "test" and len(args) >= 3:
        provider = args[1]
        query = " ".join(args[2:])
        print(f"Testing {provider} with query: {query!r}")
        print()
        try:
            results = search(query, provider=provider, limit=3)
            if not results:
                print("No results returned.")
                return
            for i, r in enumerate(results, 1):
                print(f"[{i}] {r['title']}")
                print(f"    URL: {r['url']}")
                print(f"    {r['snippet'][:200]}")
                print()
            print(f"  {len(results)} results from {provider}")
        except Exception as e:
            print(f"Error: {e}")

    else:
        print("Usage: baw --search-provider list|guide <name>|api <name>|test <name> <query>")


if __name__ == "__main__":
    main()

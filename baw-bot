#!/usr/bin/env python3
"""
BAW Bot — Multi-Platform Messaging Daemon

Connects BAW to Telegram, Discord, Signal, WhatsApp, and/or Matrix.
Runs as a persistent background process.

Usage:
  baw-bot                       # Start with default config
  baw-bot --config ~/.baw/config.yaml
  baw-bot --platform telegram   # Start only Telegram connector
  baw-bot --list                 # List available connectors
  baw-bot --help                 # This help
"""
from __future__ import annotations
import argparse
import logging
import os
import signal
import sys
import time
from pathlib import Path
from typing import Optional

# Add BAW root to path
BAW_ROOT = Path(__file__).parent.resolve()
sys.path.insert(0, str(BAW_ROOT))

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(name)s: %(message)s",
    datefmt="%H:%M:%S",
)
logger = logging.getLogger("baw-bot")


def _deep_merge(base: dict, override: dict) -> dict:
    """Recursively merge override into base. Override wins on conflict."""
    result = dict(base)
    for k, v in override.items():
        if k in result and isinstance(result[k], dict) and isinstance(v, dict):
            result[k] = _deep_merge(result[k], v)
        else:
            result[k] = v
    return result


def load_config(config_path: Optional[Path] = None) -> dict:
    """Load BAW config.yaml, merging project + user configs.

    Priority (highest wins):
      1. --config CLI argument
      2. ~/.baw/config.yaml  (user secrets — token, keys)
      3. baw/config.yaml      (project defaults — models, tools)
    """
    import yaml
    merged = {}
    for p in [
        BAW_ROOT / "config.yaml",
        Path.home() / ".baw" / "config.yaml",
    ]:
        if p.exists():
            cfg = yaml.safe_load(p.read_text(encoding="utf-8")) or {}
            merged = _deep_merge(merged, cfg)
    # CLI --config overrides everything
    if config_path and config_path.exists():
        cli_cfg = yaml.safe_load(config_path.read_text(encoding="utf-8")) or {}
        merged = _deep_merge(merged, cli_cfg)
    return merged


def main():
    parser = argparse.ArgumentParser(
        description="BAW Bot — Multi-Platform Messaging Daemon",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  baw-bot                         Start all configured connectors
  baw-bot --platform telegram     Start only Telegram
  baw-bot --platform discord      Start only Discord
  baw-bot --list                  List available connectors
  baw-bot --debug                 Verbose logging
        """,
    )
    parser.add_argument("--config", help="Path to config.yaml")
    parser.add_argument("--platform", "-p", action="append",
                        help="Only start specific platform(s) (can repeat)")
    parser.add_argument("--list", "-l", action="store_true",
                        help="List available connectors and exit")
    parser.add_argument("--debug", "-d", action="store_true",
                        help="Debug logging")
    parser.add_argument("--token", help="Override Telegram token (quick setup)")

    args = parser.parse_args()

    # ── Logging level: --debug > BAW_LOG_LEVEL > INFO ──
    log_level_name = "DEBUG" if args.debug else os.environ.get("BAW_LOG_LEVEL", "INFO")
    log_level = getattr(logging, log_level_name.upper(), logging.INFO)
    logging.getLogger().setLevel(log_level)
    # Quiet down extremely chatty libraries unless explicitly DEBUG
    if log_level > logging.DEBUG:
        for _noisy in ("httpcore", "httpx", "urllib3"):
            logging.getLogger(_noisy).setLevel(logging.WARNING)
    logging.info(f"[baw-bot] log level: {log_level_name.upper()}")

    # ── Auto-heal startup imports ──
    # If a connector's dependency is missing (ModuleNotFoundError),
    # auto-install via pip and retry before giving up.
    _KNOWN_EXTRA_DEPS = {
        "websocket": "websocket-client",
        "croniter": "croniter",
        "beautifulsoup4": "beautifulsoup4",
        "bs4": "beautifulsoup4",
        "PIL": "pillow",
        "feedparser": "feedparser",
        "markdownify": "markdownify",
        "rich": "rich",
        "fitz": "PyMuPDF",
        "pymupdf": "PyMuPDF",
        "pymupdf4llm": "pymupdf4llm",
        "faster_whisper": "faster-whisper",
        "textual": "textual",
        "tavily": "tavily-python",
        "ddgs": "ddgs",
        "mcp": "mcp",
    }

    def _safe_import(import_stmt: str) -> bool:
        """Execute an import statement, auto-install missing deps, retry."""
        try:
            exec(import_stmt)
            return True
        except ModuleNotFoundError as _e:
            _mod = str(_e).split("'")[1] if "'" in str(_e) else ""
            _pip_name = _KNOWN_EXTRA_DEPS.get(_mod, _mod)
            logging.warning(f"[AutoHeal] Missing module '{_mod}' → pip install {_pip_name}")
            import subprocess as _sp
            _r = _sp.run(
                [sys.executable, "-m", "pip", "install", _pip_name, "--quiet"],
                capture_output=True, text=True, timeout=60,
            )
            if _r.returncode == 0:
                logging.info(f"[AutoHeal] ✅ Installed '{_pip_name}', retrying import...")
                try:
                    exec(import_stmt)
                    return True
                except ModuleNotFoundError as _e2:
                    logging.error(f"[AutoHeal] ❌ Still missing after install: {_e2}")
            else:
                logging.error(f"[AutoHeal] ❌ pip install {_pip_name} failed: {_r.stderr[:200]}")
            return False

    # Load messaging connectors (with auto-heal)
    from core.messaging import list_connectors, get_connector
    _safe_import("from core.messaging.telegram import TelegramConnector")
    _safe_import("from core.messaging.discord import DiscordConnector")
    _safe_import("from core.messaging.signal import SignalConnector")
    _safe_import("from core.messaging.whatsapp import WhatsAppConnector")
    _safe_import("from core.messaging.matrix import MatrixConnector")
    _safe_import("from core.messaging.slack import SlackConnector")

    # Also ensure croniter for the scheduler
    _safe_import("import croniter")

    # Force registration by importing all connector modules
    # (The @register decorator auto-registers them)

    available = list_connectors()

    if args.list:
        print("📡 BAW Bot — Available Connectors")
        print()
        for c in available:
            print(f"  {c.name:12s}  {c.description}")
        print()
        print("Configure each platform in config.yaml under its name.")
        return

    # Auto-load .env for API keys (BAW's own)
    for env_path in [

        Path.home() / ".baw" / ".env",
    ]:
        if env_path.exists():
            for line in env_path.read_text().strip().split("\n"):
                line = line.strip()
                if line and not line.startswith("#") and "=" in line:
                    key, val = line.split("=", 1)
                    if key.strip() not in os.environ:
                        os.environ[key.strip()] = val.strip()

    # Load config
    config = load_config(Path(args.config) if args.config else None)
    if not config:
        logger.error("No config found. Run 'baw --setup' first, or specify --config")
        sys.exit(1)

    # ── Auto-discover all models from configured providers (API-driven) ──
    try:
        from core.model_discovery import auto_discover_all_models
        added = auto_discover_all_models(config)
        if added:
            logger.info(f"[Discover] Added {added} new model(s) from provider APIs")
    except Exception as e:
        logger.warning(f"[Discover] Auto-discovery skipped: {e}")

    # ── Managed scope: create managed_config.yaml from current config ──
    try:
        from core.managed_config import initialize_managed_source
        initialize_managed_source()
    except Exception as e:
        logger.warning(f"[ManagedScope] Initialization skipped: {e}")

    # ── Capability config health check & auto-heal ──
    try:
        from core.capabilities import validate_capability_health
        from core.model_discovery import _save_config
        drift_fixes = validate_capability_health(config)
        if drift_fixes:
            for fix in drift_fixes:
                logger.warning(f"[Health] {fix['capability']}: {fix['issue']} → {fix['fix_applied']}")
            _save_config(config)
            logger.info(f"[Health] Auto-healed {len(drift_fixes)} capability config drift(s)")
    except Exception as e:
        logger.debug(f"[Health] capability health check skipped: {e}")

    # Override Telegram token: CLI arg > env var > config
    if args.token:
        config.setdefault("telegram", {})["token"] = args.token
    elif os.environ.get("BAW_TELEGRAM_TOKEN"):
        config.setdefault("telegram", {})["token"] = os.environ["BAW_TELEGRAM_TOKEN"]
    elif os.environ.get("TELEGRAM_BOT_TOKEN"):
        config.setdefault("telegram", {})["token"] = os.environ["TELEGRAM_BOT_TOKEN"]

    # Determine which platforms to start
    platforms = args.platform or list(config.keys())
    platform_set = set(p.lower() for p in platforms)

    # Start connectors
    connectors = []
    for cd in available:
        if cd.config_key not in platform_set:
            continue
        platform_cfg = config.get(cd.config_key, {})
        if not platform_cfg:
            logger.info(f"[{cd.name}] No config found — skipping")
            continue

        # Check for token/api key
        if not platform_cfg.get("token") and not platform_cfg.get("phone"):
            logger.info(f"[{cd.name}] No credentials configured — skipping")
            continue

        connector = cd.handler(config, lambda msg: None)  # Pass-through handler
        connectors.append(connector)
        logger.info(f"[{cd.name}] Starting...")

    if not connectors:
        logger.warning("No connectors started. Check your config.yaml")
        logger.info("Available: " + ", ".join(c.name for c in available))
        logger.info("BAW bot will idle. Use /reload or restart after configuring connectors.")
        # Don't exit — idle so user can fix config without container restart loop

    # Start all connectors
    for c in connectors:
        c.start()

    # ── Start background scheduler (cron tasks) ──
    try:
        from core.scheduler import Scheduler
        _data_dir = Path.home() / ".baw"
        # Bootstrap: seed default schedule.yaml on fresh installs
        _schedule_path = _data_dir / "schedule.yaml"
        if not _schedule_path.exists():
            _default_schedule = Path("/app/schedule.yaml")
            if _default_schedule.exists():
                import shutil
                shutil.copy2(_default_schedule, _schedule_path)
                logger.info("[Scheduler] Seeded default schedule.yaml (fresh install)")
        _sched = Scheduler(_data_dir)
        _sched.start()
        logger.info("[Scheduler] Background daemon started")
    except Exception as e:
        logger.warning(f"[Scheduler] Failed to start: {e}")

    # ── Start health watchdog ──
    try:
        from core.watchdog import start_watchdog, get_last_health_score
        start_watchdog(interval_sec=300)  # check every 5 minutes
        logger.info(f"[Watchdog] Health monitor started (5min interval), initial score: {get_last_health_score()}/10")
    except Exception as e:
        logger.warning(f"[Watchdog] Failed to start: {e}")

    logger.info(f"🤖 BAW Bot running ({len(connectors)} connector(s))")

    # ── System guards: config validation + session auto-save (kimi B1+B2) ──
    try:
        from core.llm import validate_config
        issues = validate_config(config)
        for issue in issues:
            if issue.startswith("ERROR"):
                logger.error(f"[Config] {issue}")
            else:
                logger.warning(f"[Config] {issue}")
    except Exception as e:
        logger.warning(f"[Config] Validation skipped: {e}")

    try:
        from core.guards import SessionGuard, memory_usage_mb
        # Auto-save sessions every 60s
        _save_fn = lambda: None  # Will be set per-connector
        SessionGuard.init(lambda: logger.debug(f"[Guard] Auto-save (mem: {memory_usage_mb():.0f}MB)"),
                          interval=60)
    except Exception as e:
        logger.debug(f"[Guard] SessionGuard init: {e}")

    # Handle shutdown gracefully
    _shutdown_in_progress = [False]

    def shutdown(signum, frame):
        if _shutdown_in_progress[0]:
            logger.warning("Force shutdown (SIGTERM again)")
            os._exit(1)
        _shutdown_in_progress[0] = True
        logger.info("Shutting down gracefully...")
        
        # 1. Stop accepting new tasks
        try:
            from core.scheduler import Scheduler
            _sched.stop()
        except Exception:
            pass
        
        # 2. Signal all connectors to stop
        for c in connectors:
            try:
                c.stop()
            except Exception as e:
                logger.debug(f"[Shutdown] Connector stop: {e}")
        
        # 3. Give in-flight tasks time to drain
        drain_start = time.time()
        drain_timeout = 15  # max seconds to wait
        while time.time() - drain_start < drain_timeout:
            remaining = sum(1 for c in connectors if getattr(c, "_running", False))
            if remaining == 0:
                break
            time.sleep(0.5)
        
        # 4. Final save
        try:
            from core.guards import SessionGuard
            SessionGuard.shutdown()
        except Exception:
            pass
        
        logger.info("Shutdown complete")
        sys.exit(0)

    def reload_config(signum, frame):
        """SIGHUP: reload config without restarting the process."""
        logger.info("Reloading config (SIGHUP)...")
        try:
            from core.config import load_config
            new_config = load_config()
            # Apply changes to connectors that support it
            for c in connectors:
                if hasattr(c, "reload") and callable(c.reload):
                    c.reload(new_config)
            logger.info("Config reloaded")
        except Exception as e:
            logger.error(f"Config reload failed: {e}")

    signal.signal(signal.SIGTERM, shutdown)
    signal.signal(signal.SIGINT, shutdown)
    signal.signal(signal.SIGHUP, reload_config)

    # Keep alive
    try:
        while True:
            time.sleep(1)
    except KeyboardInterrupt:
        shutdown(None, None)


if __name__ == "__main__":
    # ── ModuleNotFoundError auto-heal ──
    # If main() crashes because a third-party module isn't installed,
    # auto-install it via pip and retry once.
    try:
        main()
    except ModuleNotFoundError as _e_heal:
        _mod_heal = str(_e_heal).split("'")[1] if "'" in str(_e_heal) else ""
        _pip_heal = {"websocket": "websocket-client", "PIL": "pillow", "bs4": "beautifulsoup4"}.get(_mod_heal, _mod_heal)
        if _mod_heal and _mod_heal not in ("pip", "setuptools"):
            import subprocess as _sp
            _sp.run([sys.executable, "-m", "pip", "install", _pip_heal, "--quiet"], timeout=60)
            main()

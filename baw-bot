#!/usr/bin/env python3
"""
BAW Bot — Multi-Platform Messaging Daemon

Connects BAW to Telegram, Discord, Signal, WhatsApp, and/or Matrix.
Runs as a persistent background process.

Usage:
  baw-bot                       # Start with default config
  baw-bot --config ~/.baw/config.yaml
  baw-bot --platform telegram   # Start only Telegram connector
  baw-bot --list                 # List available connectors
  baw-bot --help                 # This help
"""
from __future__ import annotations
import argparse
import logging
import os
import signal
import sys
import time
from pathlib import Path
from typing import Optional

# Add BAW root to path
BAW_ROOT = Path(__file__).parent.resolve()
sys.path.insert(0, str(BAW_ROOT))

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(name)s: %(message)s",
    datefmt="%H:%M:%S",
)
logger = logging.getLogger("baw-bot")


def _deep_merge(base: dict, override: dict) -> dict:
    """Recursively merge override into base. Override wins on conflict."""
    result = dict(base)
    for k, v in override.items():
        if k in result and isinstance(result[k], dict) and isinstance(v, dict):
            result[k] = _deep_merge(result[k], v)
        else:
            result[k] = v
    return result


def load_config(config_path: Optional[Path] = None) -> dict:
    """Load BAW config.yaml, merging project + user configs.

    Priority (highest wins):
      1. --config CLI argument
      2. ~/.baw/config.yaml  (user secrets — token, keys)
      3. baw/config.yaml      (project defaults — models, tools)
    """
    import yaml
    merged = {}
    for p in [
        BAW_ROOT / "config.yaml",
        Path.home() / ".baw" / "config.yaml",
    ]:
        if p.exists():
            cfg = yaml.safe_load(p.read_text(encoding="utf-8")) or {}
            merged = _deep_merge(merged, cfg)
    # CLI --config overrides everything
    if config_path and config_path.exists():
        cli_cfg = yaml.safe_load(config_path.read_text(encoding="utf-8")) or {}
        merged = _deep_merge(merged, cli_cfg)
    return merged


def main():
    parser = argparse.ArgumentParser(
        description="BAW Bot — Multi-Platform Messaging Daemon",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  baw-bot                         Start all configured connectors
  baw-bot --platform telegram     Start only Telegram
  baw-bot --platform discord      Start only Discord
  baw-bot --list                  List available connectors
  baw-bot --debug                 Verbose logging
        """,
    )
    parser.add_argument("--config", help="Path to config.yaml")
    parser.add_argument("--platform", "-p", action="append",
                        help="Only start specific platform(s) (can repeat)")
    parser.add_argument("--list", "-l", action="store_true",
                        help="List available connectors and exit")
    parser.add_argument("--debug", "-d", action="store_true",
                        help="Debug logging")
    parser.add_argument("--token", help="Override Telegram token (quick setup)")

    args = parser.parse_args()

    # ── Logging level: --debug > BAW_LOG_LEVEL > INFO ──
    log_level_name = "DEBUG" if args.debug else os.environ.get("BAW_LOG_LEVEL", "INFO")
    log_level = getattr(logging, log_level_name.upper(), logging.INFO)
    logging.getLogger().setLevel(log_level)
    # Quiet down extremely chatty libraries unless explicitly DEBUG
    if log_level > logging.DEBUG:
        for _noisy in ("httpcore", "httpx", "urllib3"):
            logging.getLogger(_noisy).setLevel(logging.WARNING)
    logging.info(f"[baw-bot] log level: {log_level_name.upper()}")

    # Load messaging connectors
    from core.messaging import list_connectors, get_connector
    from core.messaging.telegram import TelegramConnector
    from core.messaging.discord import DiscordConnector
    from core.messaging.signal import SignalConnector
    from core.messaging.whatsapp import WhatsAppConnector
    from core.messaging.matrix import MatrixConnector

    # Force registration by importing all connector modules
    # (The @register decorator auto-registers them)

    available = list_connectors()

    if args.list:
        print("📡 BAW Bot — Available Connectors")
        print()
        for c in available:
            print(f"  {c.name:12s}  {c.description}")
        print()
        print("Configure each platform in config.yaml under its name.")
        return

    # Auto-load .env for API keys (Hermes profile first, then BAW's own)
    for env_path in [

        Path.home() / ".baw" / ".env",
    ]:
        if env_path.exists():
            for line in env_path.read_text().strip().split("\n"):
                line = line.strip()
                if line and not line.startswith("#") and "=" in line:
                    key, val = line.split("=", 1)
                    if key.strip() not in os.environ:
                        os.environ[key.strip()] = val.strip()

    # Load config
    config = load_config(Path(args.config) if args.config else None)
    if not config:
        logger.error("No config found. Run 'baw --setup' first, or specify --config")
        sys.exit(1)

    # Override Telegram token: CLI arg > env var > config
    if args.token:
        config.setdefault("telegram", {})["token"] = args.token
    elif os.environ.get("BAW_TELEGRAM_TOKEN"):
        config.setdefault("telegram", {})["token"] = os.environ["BAW_TELEGRAM_TOKEN"]

    # Determine which platforms to start
    platforms = args.platform or list(config.keys())
    platform_set = set(p.lower() for p in platforms)

    # Start connectors
    connectors = []
    for cd in available:
        if cd.config_key not in platform_set:
            continue
        platform_cfg = config.get(cd.config_key, {})
        if not platform_cfg:
            logger.info(f"[{cd.name}] No config found — skipping")
            continue

        # Check for token/api key
        if not platform_cfg.get("token") and not platform_cfg.get("phone"):
            logger.info(f"[{cd.name}] No credentials configured — skipping")
            continue

        connector = cd.handler(config, lambda msg: None)  # Pass-through handler
        connectors.append(connector)
        logger.info(f"[{cd.name}] Starting...")

    if not connectors:
        logger.warning("No connectors started. Check your config.yaml")
        logger.info("Available: " + ", ".join(c.name for c in available))
        sys.exit(1)

    # Start all connectors
    for c in connectors:
        c.start()

    logger.info(f"🤖 BAW Bot running ({len(connectors)} connector(s))")

    # ── System guards: config validation + session auto-save (kimi B1+B2) ──
    try:
        from core.llm import validate_config
        issues = validate_config(config)
        for issue in issues:
            if issue.startswith("ERROR"):
                logger.error(f"[Config] {issue}")
            else:
                logger.warning(f"[Config] {issue}")
    except Exception as e:
        logger.warning(f"[Config] Validation skipped: {e}")

    try:
        from core.guards import SessionGuard, memory_usage_mb
        # Auto-save sessions every 60s
        _save_fn = lambda: None  # Will be set per-connector
        SessionGuard.init(lambda: logger.debug(f"[Guard] Auto-save (mem: {memory_usage_mb():.0f}MB)"),
                          interval=60)
    except Exception as e:
        logger.debug(f"[Guard] SessionGuard init: {e}")

    # Handle shutdown gracefully
    def shutdown(signum, frame):
        logger.info("Shutting down...")
        try:
            from core.guards import SessionGuard
            SessionGuard.shutdown()
        except Exception:
            pass
        for c in connectors:
            c.stop()
        sys.exit(0)

    signal.signal(signal.SIGTERM, shutdown)
    signal.signal(signal.SIGINT, shutdown)

    # Keep alive
    try:
        while True:
            time.sleep(1)
    except KeyboardInterrupt:
        shutdown(None, None)


if __name__ == "__main__":
    main()

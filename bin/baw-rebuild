#!/usr/bin/env bash
# ── BAW quick-rebuild helper ──
# Usage:
#   baw-rebuild           → fast rebuild (uses Docker layer cache)
#   baw-rebuild --clean   → full rebuild from scratch (when deps change)
#   baw-rebuild --up      → fast rebuild + up -d
#   baw-rebuild -cu       → clean rebuild + up -d
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

CLEAN=false
UP=false

for arg in "$@"; do
    case "$arg" in
        --clean|-c) CLEAN=true ;;
        --up|-u) UP=true ;;
        -cu|--clean-up) CLEAN=true; UP=true ;;
    esac
done

if $CLEAN; then
    echo "🧹 Full rebuild (--no-cache)..."
    docker compose build --no-cache
else
    echo "⚡ Fast rebuild (using layer cache)..."
    docker compose build
fi

if $UP; then
    docker compose up -d
    echo "✅ BAW container restarted"
else
    echo "💡 Run 'docker compose up -d' to restart, or use --up flag"
fi

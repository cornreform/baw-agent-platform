#!/usr/bin/env bash
# baw — BAW CLI wrapper (host-side)
# Proxies commands into the Docker container.
set -e

CONTAINER="baw-telegram"

# Check if container is running
if ! docker ps --format '{{.Names}}' | grep -qx "$CONTAINER"; then
    echo "❌ BAW container '${CONTAINER}' is not running."
    echo "   Start it: cd ~/baw && docker compose up -d"
    exit 1
fi

# Detect if we have a real TTY
TTY_FLAG=""
if [ -t 0 ] && [ -t 1 ]; then
    TTY_FLAG="-it"
else
    TTY_FLAG="-i"
fi

# Pass all args to the container's CLI
exec docker exec ${TTY_FLAG} "$CONTAINER" python3 -m cli.main "$@"

[Unit]
Description=BAW Bot Docker Compose
Requires=docker.service
After=docker.service network-online.target

# ── SETUP INSTRUCTIONS ──
# 1. Edit User below to match your username
# 2. Copy: sudo cp deploy/baw-docker.service /etc/systemd/system/
# 3. Run: sudo systemctl daemon-reload && sudo systemctl enable --now baw-docker

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=%h/baw
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
User=%u

[Install]
WantedBy=multi-user.target

[Unit]
Description=BAW Bot — Telegram Messenger Connector
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=radxa
Group=radxa
WorkingDirectory=/home/radxa/baw
EnvironmentFile=/home/radxa/.baw/.env
ExecStart=/home/radxa/.hermes/hermes-agent/venv/bin/python3 -u /home/radxa/baw/baw-bot --platform telegram --debug
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
